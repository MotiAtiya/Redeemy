rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is a member of a given family
    function isFamilyMember(familyId) {
      return familyId != null &&
        exists(/databases/$(database)/documents/families/$(familyId)) &&
        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }

    // Helper: check if user is the admin of a given family
    function isFamilyAdmin(familyId) {
      return familyId != null &&
        exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/families/$(familyId)).data.adminId == request.auth.uid;
    }

    // Users — each user can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Credits — owner OR family member can read/write
    match /credits/{creditId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      // Only the credit owner OR the family admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyAdmin(resource.data.familyId)
      );
    }

    // Warranties — owner OR family member can read/write
    match /warranties/{warrantyId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      // Only the warranty owner OR the family admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyAdmin(resource.data.familyId)
      );
    }

    // Subscriptions — owner OR family member can read/write
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      // Only the subscription owner OR the family admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyAdmin(resource.data.familyId)
      );
    }

    // Occasions — owner OR family member can read/write
    match /occasions/{occasionId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      // Only the occasion owner OR the family admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyAdmin(resource.data.familyId)
      );
    }

    // Documents — owner OR family member can read/write
    match /documents/{documentId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyMember(resource.data.familyId)
      );

      // Only the document owner OR the family admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isFamilyAdmin(resource.data.familyId)
      );
    }

    // Events — write-only audit log consumed by the admin dashboard.
    // Clients can create their own events; reads/updates/deletes are
    // server-only via the Admin SDK.
    match /events/{eventId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Families collection
    match /families/{familyId} {
      // Any authenticated user can read to validate an invite code
      allow read: if request.auth != null;

      // Only authenticated users can create (they must set themselves as admin)
      allow create: if request.auth != null &&
        request.resource.data.adminId == request.auth.uid;

      // Update — three distinct cases:
      allow update: if request.auth != null && (

        // Case 1: Admin can update any field
        resource.data.adminId == request.auth.uid ||

        // Case 2: Non-admin current member can update (leave, etc.)
        // but cannot change protected fields
        (
          request.auth.uid in resource.data.members &&
          resource.data.adminId != request.auth.uid &&
          request.resource.data.adminId == resource.data.adminId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.maxMembers == resource.data.maxMembers &&
          request.resource.data.inviteCode == resource.data.inviteCode &&
          request.resource.data.inviteCodeExpiresAt == resource.data.inviteCodeExpiresAt
        ) ||

        // Case 3: Non-member joining with a valid, unexpired invite code
        // Critical fields must be unchanged — the client cannot forge an extension
        (
          !(request.auth.uid in resource.data.members) &&
          resource.data.inviteCodeExpiresAt > request.time &&
          resource.data.members.size() < resource.data.maxMembers &&
          request.resource.data.adminId == resource.data.adminId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.maxMembers == resource.data.maxMembers &&
          request.resource.data.inviteCode == resource.data.inviteCode &&
          request.resource.data.inviteCodeExpiresAt == resource.data.inviteCodeExpiresAt
        )
      );

      // Only admin can delete the family
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.adminId;
    }
  }
}
