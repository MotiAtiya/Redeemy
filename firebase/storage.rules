rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Credit images — only the credit owner can read/write
    // Path: credits/{creditId}/full.jpg  or  credits/{creditId}/thumb.jpg
    match /credits/{creditId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024   // max 5 MB per upload
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
