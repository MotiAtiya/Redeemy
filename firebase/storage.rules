rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Credit images
    // Path: credits/{creditId}/full.jpg  or  credits/{creditId}/thumb.jpg
    match /credits/{creditId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Warranty images
    // Path: warranties/{warrantyId}/{index}_full.jpg  or  warranties/{warrantyId}/{index}_thumb.jpg
    match /warranties/{warrantyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Document images
    // Path: documents/{documentId}/full.jpg  or  documents/{documentId}/thumb.jpg
    match /documents/{documentId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
